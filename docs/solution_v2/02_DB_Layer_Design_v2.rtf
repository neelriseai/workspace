\par
\par
\b \fs24 7.5 Query candidate retrieval behavior \b0\fs22\par
\par
SELECT app_id,page_name,element_name,field_type,success_count,last_seen\par
FROM elements\par
WHERE app_id='demo-qa-app' AND page_name='text_box' AND field_type='textbox'\par
ORDER BY success_count DESC, last_seen DESC\par
LIMIT 25;\par
\par
\par
\b \fs24 7.6 Insert event and verify \b0\fs22\par
\par
INSERT INTO events(correlation_id,app_id,page_name,element_name,field_type,stage,status,score,details)\par
VALUES ('corr-001','demo-qa-app','text_box','full_name','textbox','metadata','ok',0.91,'\{"source":"manual_test"\}'::jsonb);\par
\par
SELECT correlation_id, stage, status, score, timestamp\par
FROM events\par
ORDER BY id DESC\par
LIMIT 20;\par
\par
\par
\b \fs24 7.7 Optional pgvector smoke \b0\fs22\par
\par
ALTER TABLE elements ALTER COLUMN signature_embedding TYPE vector(3);\par
UPDATE elements SET signature_embedding='[0.1,0.2,0.3]' WHERE signature_embedding IS NULL;\par
SELECT id, 1 - (signature_embedding <=> '[0.1,0.2,0.3]') AS similarity\par
FROM elements\par
ORDER BY signature_embedding <=> '[0.1,0.2,0.3]'\par
LIMIT 5;\par
\par
