OPENAI_API_KEY=<your-openai-key-placeholder>
XH_ADAPTER=playwright_python
XH_PG_DSN=postgresql://<user>:<password>@<host>:5432/<db>
XH_CHROMA_PATH=artifacts/chroma
XH_CHROMA_RAG_COLLECTION=xh_rag_documents
XH_CHROMA_ELEMENTS_COLLECTION=xh_elements
XH_PG_POOL_MIN=1
XH_PG_POOL_MAX=10
XH_PG_AUTO_INIT_SCHEMA=true
XH_METADATA_JSON_DIR=artifacts/metadata
XH_RAG_ENABLED=true
XH_RAG_TOP_K=5
XH_RAG_PROMPT_TOP_N=3
XH_OPENAI_MODEL=gpt-4.1
XH_OPENAI_EMBED_MODEL=text-embedding-3-large
XH_OPENAI_EMBED_DIM=1536
XH_EMBEDDING_WRITE_ENABLED=true
XH_RAG_DOC_MAX_CHARS=1400
XH_PROMPT_GRAPH_DEEP_DEFAULT=true
XH_PROMPT_GRAPH_DEEP_RETRY_ENABLED=true
XH_PROMPT_GRAPH_DEEP_RETRY_MAX=1
XH_LLM_MIN_CONFIDENCE_FOR_ACCEPT=0.65
XH_STAGE_PROFILE=llm_only
XH_STAGE_FALLBACK_ENABLED=false
XH_STAGE_METADATA_ENABLED=false
XH_STAGE_RULES_ENABLED=false
XH_STAGE_FINGERPRINT_ENABLED=false
XH_STAGE_PAGE_INDEX_ENABLED=false
XH_STAGE_SIGNATURE_ENABLED=false
XH_STAGE_DOM_MINING_ENABLED=false
XH_STAGE_DEFAULTS_ENABLED=false
XH_STAGE_POSITION_ENABLED=false
XH_STAGE_RAG_ENABLED=true
XH_FINGERPRINT_ENABLED=false
XH_FINGERPRINT_MIN_SCORE=0.75
XH_FINGERPRINT_ACCEPT_SCORE=0.90
XH_FINGERPRINT_CANDIDATE_LIMIT=25
XH_RETRY_ENABLED=true
XH_RETRY_MAX_ATTEMPTS=2
XH_RETRY_DELAY_MS=30
XH_RETRY_REASON_CODES=locator_error,locator_timeout,stale_element,not_visible
